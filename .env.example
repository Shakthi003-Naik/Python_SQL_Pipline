# ── Alpha Vantage API ──────────────────────────────────
# Get your free key at: https://www.alphavantage.co/support/#api-key
API_KEY=your_alpha_vantage_api_key_here

# Stock symbols to monitor (comma-separated, no spaces)
SYMBOLS=AAPL,MSFT,GOOGL

# ── MySQL Database ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=market_pipeline
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# ── Pipeline Settings ──────────────────────────────────
# How often to run the pipeline (in minutes)
SCHEDULE_INTERVAL_MINUTES=15

# Anomaly detection — z-score threshold (3.0 = 3 std deviations)
ANOMALY_ZSCORE_THRESHOLD=3.0

# Number of past days to use when calculating baseline stats
ANOMALY_LOOKBACK_DAYS=30

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log
